# =============================================================================
# .env.example — Environment Configuration Template
# Copy to .env and fill in all values before running docker compose.
# NEVER commit .env to version control — .gitignore it.
# =============================================================================


# -----------------------------------------------------------------------------
# DJANGO CORE
# -----------------------------------------------------------------------------

# Flip to False in production. Never expose True on a public server.
DJANGO_DEBUG=False

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=CHANGE_ME_generate_a_secure_random_string_here

# Comma-separated list of allowed hostnames / IPs (no spaces)
# Example: yourdomain.com,www.yourdomain.com,YOUR_SERVER_IP
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Django CSRF trusted origins (required for POST requests through Nginx/TLS)
# Example: https://yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com

# Internal application port (used by Gunicorn inside the container)
DJANGO_INTERNAL_PORT=8000

# Number of Gunicorn worker processes.
# Rule of thumb: (2 × CPU cores) + 1
GUNICORN_WORKERS=4


# -----------------------------------------------------------------------------
# POSTGRESQL + TIMESCALEDB
# The `db` service hostname is the Docker service name — do not change.
# -----------------------------------------------------------------------------

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=pipeline_gold
POSTGRES_USER=pipeline_user
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password

# Separate database for Dagster's internal run/event log storage
DAGSTER_POSTGRES_DB=dagster

# Full DSN used by Django's DATABASE_URL setting (dj-database-url compatible)
# Format: postgres://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=postgres://pipeline_user:CHANGE_ME_strong_postgres_password@db:5432/pipeline_gold


# -----------------------------------------------------------------------------
# REDIS (Arq Queue + Django Cache)
# The `redis` service hostname is the Docker service name.
# -----------------------------------------------------------------------------

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_MAX_MEMORY=512mb

# Full Redis DSN — used by Arq WorkerSettings and Django cache backend
# Format: redis://:PASSWORD@HOST:PORT/DB_INDEX
REDIS_URL=redis://:CHANGE_ME_strong_redis_password@redis:6379/0

# Separate DB index for Django's cache (keep isolated from Arq job queue)
DJANGO_CACHE_REDIS_URL=redis://:CHANGE_ME_strong_redis_password@redis:6379/1


# -----------------------------------------------------------------------------
# CLOUDFLARE R2 / S3-COMPATIBLE OBJECT STORAGE
# Bronze (.jsonl.gz) and Silver (.parquet) immutable layer storage.
# Files written here are NEVER overwritten — see CLAUDE.md §3.
# -----------------------------------------------------------------------------

R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key

# Bucket names — keep bronze and silver separated for IAM scoping
R2_BRONZE_BUCKET=pipeline-bronze
R2_SILVER_BUCKET=pipeline-silver

# S3-compatible endpoint for boto3 / s3fs clients
R2_ENDPOINT_URL=https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com

# AWS region placeholder required by boto3 (R2 ignores this value)
AWS_DEFAULT_REGION=auto


# -----------------------------------------------------------------------------
# SCRAPING ENGINE
# Per CLAUDE.md §4: hard cap at 5 concurrent workers per domain.
# These defaults are read by WorkerSettings and can be overridden live
# via the Django Admin (SiteConfig model throttle fields).
# -----------------------------------------------------------------------------

# Global max concurrent Arq jobs across ALL domains
ARQ_MAX_JOBS=50

# Default per-domain concurrency ceiling (overridable per SiteConfig in DB)
SCRAPER_MAX_CONCURRENCY_PER_DOMAIN=5

# Seconds to wait between retries on a failed request
SCRAPER_RETRY_BACKOFF_SECONDS=5

# curl_cffi browser impersonation profile
SCRAPER_IMPERSONATE_PROFILE=chrome


# -----------------------------------------------------------------------------
# PROXY CONFIGURATION (Optional — configure in config/proxies.yaml if used)
# -----------------------------------------------------------------------------

# Proxy provider API key (e.g., Bright Data, Oxylabs, Smartproxy)
PROXY_API_KEY=

# Rotating proxy endpoint (leave blank to disable proxy rotation)
PROXY_ENDPOINT=


# -----------------------------------------------------------------------------
# DAGSTER ORCHESTRATION
# -----------------------------------------------------------------------------

DAGSTER_HOME=/opt/dagster/dagster_home

# Dagster run coordinator: use QueuedRunCoordinator for production
# Options: DefaultRunCoordinator | QueuedRunCoordinator
DAGSTER_RUN_COORDINATOR=QueuedRunCoordinator


# -----------------------------------------------------------------------------
# MONITORING & ALERTING (Optional)
# -----------------------------------------------------------------------------

# Sentry DSN for error tracking (leave blank to disable)
SENTRY_DSN=

# Environment tag sent to Sentry
SENTRY_ENVIRONMENT=production

# Slack webhook for pipeline failure alerts (leave blank to disable)
SLACK_ALERT_WEBHOOK_URL=


# -----------------------------------------------------------------------------
# SECURITY HEADERS (read by Django settings)
# -----------------------------------------------------------------------------

# Force HTTPS redirects (set True in production behind TLS termination)
DJANGO_SECURE_SSL_REDIRECT=True

# HSTS max-age in seconds (31536000 = 1 year)
DJANGO_SECURE_HSTS_SECONDS=31536000
