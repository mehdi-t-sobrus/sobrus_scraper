# =============================================================================
# .env.example — Docker deployment environment variables
# Copy to .env and fill in values before running docker compose up
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=pipeline_gold
POSTGRES_USER=pipeline_user
POSTGRES_PASSWORD=                     # REQUIRED — choose a strong password

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
DJANGO_SECRET_KEY=                     # REQUIRED — openssl rand -hex 32
DJANGO_ALLOWED_HOSTS=localhost,yourdomain.com
DJANGO_API_KEY=                        # REQUIRED — openssl rand -hex 32

# ---------------------------------------------------------------------------
# Cloudflare R2 storage
# Set R2_LOCAL_DEV_MODE=True to use local data/ volumes instead of R2
# ---------------------------------------------------------------------------
R2_LOCAL_DEV_MODE=False
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BRONZE_BUCKET=pipeline-bronze
R2_SILVER_BUCKET=pipeline-silver

# ---------------------------------------------------------------------------
# Proxy pool fallback (primary config is via Django Admin → Proxy Pool)
# ---------------------------------------------------------------------------
PROXY_LIST=
PROXY_ENDPOINT=

# ---------------------------------------------------------------------------
# Dagster
# ---------------------------------------------------------------------------
DAGSTER_PORT=3000

# ---------------------------------------------------------------------------
# Tuning (optional — defaults shown)
# ---------------------------------------------------------------------------
GUNICORN_WORKERS=4
SCRAPER_MAX_CONCURRENCY_PER_DOMAIN=5
