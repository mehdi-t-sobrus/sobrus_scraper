# =============================================================================
# src/matching/.env.example
# Gold entity resolution layer — copy to .env and fill in values
# =============================================================================

# Django settings
DJANGO_SETTINGS_MODULE=core.settings

# ---------------------------------------------------------------------------
# Cloudflare R2 — Silver bucket (read-only for matching layer)
# ---------------------------------------------------------------------------
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_SILVER_BUCKET=pipeline-silver

# Set True to read Silver from local data/silver/ instead of R2
R2_LOCAL_DEV_MODE=True

# ---------------------------------------------------------------------------
# Matching thresholds — adjust to tune precision/recall trade-off
# ---------------------------------------------------------------------------
# Tier 3: normalised name token-sort auto-match threshold (0.0-1.0)
MATCHING_TIER3_THRESHOLD=0.95

# Tier 4: vector cosine auto-match threshold
MATCHING_TIER4_AUTO=0.90

# Tier 5: vector cosine review threshold (below this = new product)
MATCHING_TIER5_REVIEW=0.65
