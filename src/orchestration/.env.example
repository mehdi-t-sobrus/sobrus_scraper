# =============================================================================
# src/orchestration/.env.example
# Dagster orchestration layer — copy to .env and fill in values
# =============================================================================

# ---------------------------------------------------------------------------
# Django (for ORM access to monitor scraping progress)
# ---------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=core.settings
DJANGO_API_BASE=http://localhost:8000/api/v1
DJANGO_API_KEY=dev-api-key-changeme

# ---------------------------------------------------------------------------
# PostgreSQL (same as backend)
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pipeline_gold
POSTGRES_USER=pipeline_user
POSTGRES_PASSWORD=localpassword

# ---------------------------------------------------------------------------
# Redis (to check Arq queue depth)
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# R2 / local dev
# ---------------------------------------------------------------------------
R2_LOCAL_DEV_MODE=True
R2_BRONZE_BUCKET=pipeline-bronze
R2_SILVER_BUCKET=pipeline-silver

# ---------------------------------------------------------------------------
# Dagster instance storage (local SQLite for dev, PostgreSQL for prod)
# ---------------------------------------------------------------------------
DAGSTER_HOME=.dagster

# ---------------------------------------------------------------------------
# Pipeline paths (relative to repo root)
# ---------------------------------------------------------------------------
DBT_PROJECT_DIR=src/transformations
DBT_PROFILES_DIR=src/transformations
