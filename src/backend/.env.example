# =============================================================================
# src/backend/.env.example
# Django backend — copy to .env and fill in values
# =============================================================================

# ---------------------------------------------------------------------------
# Django core
# ---------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-use-openssl-rand-hex-64
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
DJANGO_LOG_LEVEL=INFO

# API key for machine-to-machine access (Arq workers, Dagster, curl)
# Generate with: openssl rand -hex 32
DJANGO_API_KEY=dev-api-key-changeme

# ---------------------------------------------------------------------------
# PostgreSQL + TimescaleDB
# ---------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=pipeline_gold
POSTGRES_USER=pipeline_user
POSTGRES_PASSWORD=localpassword

# ---------------------------------------------------------------------------
# Redis (Django cache only — queue handled by scrapers/.env)
# ---------------------------------------------------------------------------
DJANGO_CACHE_REDIS_URL=redis://localhost:6379/1

# ---------------------------------------------------------------------------
# Cloudflare R2 (Django reads bucket names for API responses)
# ---------------------------------------------------------------------------
R2_BRONZE_BUCKET=pipeline-bronze
R2_SILVER_BUCKET=pipeline-silver

# ---------------------------------------------------------------------------
# Security (safe defaults for local dev — harden in production)
# ---------------------------------------------------------------------------
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=0
