# =============================================================================
# src/scrapers/.env.example
# Arq workers + discoverer — copy to .env and fill in values
# =============================================================================

# ---------------------------------------------------------------------------
# Django API (workers talk to Django via HTTP, not ORM directly)
# ---------------------------------------------------------------------------
DJANGO_API_BASE=http://localhost:8000/api/v1
DJANGO_API_KEY=dev-api-key-changeme
DJANGO_SETTINGS_MODULE=core.settings

# ---------------------------------------------------------------------------
# Redis — Arq job queue
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Cloudflare R2 — Bronze bucket (workers write here)
# ---------------------------------------------------------------------------
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BRONZE_BUCKET=pipeline-bronze

# Set to True to write Bronze files locally to /tmp/bronze/ instead of R2.
# Only for development — never in production.
R2_LOCAL_DEV_MODE=False

# ---------------------------------------------------------------------------
# Scraper engine tunables
# ---------------------------------------------------------------------------
SCRAPER_IMPERSONATE_PROFILE=chrome
SCRAPER_MAX_CONCURRENCY_PER_DOMAIN=5
SCRAPER_REQUEST_TIMEOUT_SECONDS=30
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_BACKOFF_SECONDS=5
R2_FLUSH_BATCH_SIZE=500
R2_MULTIPART_CHUNK_BYTES=5242880

# How many days before a done/failed URL is eligible for re-scraping
DISCOVERER_RESCRAPE_AFTER_DAYS=30

# ---------------------------------------------------------------------------
# Arq worker
# ---------------------------------------------------------------------------
ARQ_MAX_JOBS=50

# ---------------------------------------------------------------------------
# Proxy pool (optional — leave blank to use host IP in dev)
# ---------------------------------------------------------------------------
# Proxies are primarily configured via Django Admin → Proxy Pool.
# The vars below are fallbacks if the Django API is unreachable.
#
# Option A — Comma-separated list of proxy DSNs:
#   PROXY_LIST=http://user:pass@host1:port,http://user:pass@host2:port
#
# Option B — Single rotating gateway endpoint:
#   PROXY_ENDPOINT=http://user:pass@rotating.provider.com:8080
#
# Recommended providers for Moroccan sites:
#   - BrightData (residential):  https://brightdata.com
#   - Oxylabs (residential):     https://oxylabs.io
#   - IPRoyal (residential):     https://iproyal.com
#   DSN format: http://<username>:<password>@<gateway_host>:<port>
#
PROXY_LIST=
PROXY_ENDPOINT=
