# ---------------------------------------------------------------------------
# Local dev data (Bronze/Silver files) — can be large, never commit
# ---------------------------------------------------------------------------
data/

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/

# ---------------------------------------------------------------------------
# Environment files — never commit secrets
# Keep .env.example files so others know what vars to set
# ---------------------------------------------------------------------------
.env
!.env.example

# ---------------------------------------------------------------------------
# macOS
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# ---------------------------------------------------------------------------
# Editors
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ---------------------------------------------------------------------------
# dbt
# ---------------------------------------------------------------------------
src/transformations/target/
src/transformations/dbt_packages/
src/transformations/logs/
src/transformations/dev.duckdb

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
src/backend/staticfiles/
src/backend/media/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/

# ---------------------------------------------------------------------------
# Dagster instance storage — local SQLite run history
# ---------------------------------------------------------------------------
.dagster/storage/
.dagster/*.db
.dagster/schedules/

# ---------------------------------------------------------------------------
# Generated reports
# ---------------------------------------------------------------------------
sql/reports/
*.bin
*.safetensors
models/
